# Database
# For local development with PostgreSQL (Docker or local install):
DATABASE_URL="postgresql://postgres:password@localhost:5432/arcade_dev"

# For Neon (free cloud PostgreSQL - recommended for Vercel):
# DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"
# DIRECT_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# JWT Secret - generate with: openssl rand -hex 32
JWT_SECRET="your-secret-key-at-least-32-characters-long-here"

# App URL - used to build referral links
NEXT_PUBLIC_APP_URL="http://localhost:3000"
